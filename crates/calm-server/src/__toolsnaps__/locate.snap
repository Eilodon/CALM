{
  "name": "locate",
  "description": "Compound: search + file_overview + symbol_info in 1 call (66% reduction). USE INSTEAD OF calling search then file_overview then symbol_info separately. NOT FOR: reading source (use source after locate), pre-edit (use edit_context).",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "required": [
      "query"
    ],
    "type": "object",
    "properties": {
      "query": {
        "type": "string"
      },
      "kind": {
        "description": "Same values as `search`'s `kind` — `\"symbol\"` (default), `\"text\"`,\n`\"file\"`, `\"semantic\"`, or `\"hybrid\"`.",
        "type": [
          "string",
          "null"
        ]
      },
      "depth": {
        "description": "How much to enrich the top hit beyond `results`, in increasing\ncost/token size:\n- `\"search_only\"`: just `results` — cheapest, use when you only\n  need the match list (e.g. checking existence, or `kind` is\n  `\"text\"`/`\"file\"` where there's no symbol to enrich anyway).\n- `\"with_file\"`: adds `file_overview` (every symbol in the top\n  hit's file, with signatures) — can be large for a big file.\n- `\"with_symbol\"` (default): adds both `file_overview` and\n  `top_symbol` (full metadata for just the top hit).\n\n`kind` `\"text\"`/`\"file\"` auto-downgrades `\"with_symbol\"` to\n`\"with_file\"` (reported via `depth_adjusted`) since a text/file\nmatch has no single symbol to enrich.",
        "type": [
          "string",
          "null"
        ]
      },
      "limit": {
        "description": "Max entries in `results`. Default 10.",
        "type": [
          "integer",
          "null"
        ],
        "format": "uint",
        "minimum": 0
      }
    }
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$defs": {
      "ErrorDetail": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "recoverable": {
            "type": "boolean"
          }
        },
        "required": [
          "code",
          "message",
          "recoverable"
        ]
      },
      "SearchResultItem": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "kind": {
            "type": [
              "string",
              "null"
            ]
          },
          "line_start": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "line_end": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "score": {
            "type": [
              "number",
              "null"
            ],
            "format": "double"
          },
          "match_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "snippet": {
            "description": "`kind=\"grep\"` only: the matched line with `context` lines of\nsurrounding text, 1-indexed and marked.",
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "name",
          "path"
        ]
      },
      "SymbolInfoOutput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "qualified_name": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "line_start": {
            "type": "integer",
            "format": "int64"
          },
          "line_end": {
            "type": "integer",
            "format": "int64"
          },
          "signature": {
            "type": [
              "string",
              "null"
            ]
          },
          "docstring": {
            "type": [
              "string",
              "null"
            ]
          },
          "caller_count": {
            "type": "integer",
            "format": "int64"
          },
          "is_hub": {
            "type": "boolean"
          },
          "coreness": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "health": {
            "anyOf": [
              {
                "$ref": "#/$defs/HealthOutput"
              },
              {
                "type": "null"
              }
            ]
          },
          "suggested_next": {
            "anyOf": [
              {
                "$ref": "#/$defs/SuggestedNext"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "name",
          "qualified_name",
          "kind",
          "path",
          "line_start",
          "line_end",
          "caller_count",
          "is_hub"
        ]
      },
      "HealthOutput": {
        "type": "object",
        "properties": {
          "dead_code_confidence": {
            "type": "string"
          },
          "dead_code_source": {
            "type": "string"
          },
          "caller_count_by_confidence": {
            "anyOf": [
              {
                "$ref": "#/$defs/CallerCountByConfidence"
              },
              {
                "type": "null"
              }
            ]
          },
          "test_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "dead_code_confidence",
          "dead_code_source",
          "test_files"
        ]
      },
      "CallerCountByConfidence": {
        "type": "object",
        "properties": {
          "formal": {
            "type": "integer",
            "format": "int64"
          },
          "resolved": {
            "type": "integer",
            "format": "int64"
          },
          "inferred": {
            "type": "integer",
            "format": "int64"
          },
          "textual": {
            "type": "integer",
            "format": "int64"
          },
          "ambiguous": {
            "description": "Bare-name matches fanned out across >1 same-named candidate with no\ntie-breaker — most likely correct for at most one of them. See\n`EdgeConfidence::Ambiguous`.",
            "type": "integer",
            "format": "int64"
          }
        },
        "required": [
          "formal",
          "resolved",
          "inferred",
          "textual",
          "ambiguous"
        ]
      },
      "SuggestedNext": {
        "type": "object",
        "properties": {
          "tool": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "args": true,
          "gate": {
            "description": "Plan 3 §3.5(b): `Some(true)` iff skipping `tool` is actually\nhook-enforced (currently only the edit_context/edit_lines/edit_symbol\n→ diff_impact hints set this, via `suggested_gated`) — every other\nhint is left unset (`None`), meaning advisory-only. Lets an agent\ntell \"you'll be blocked if you skip this\" apart from \"you probably\nwant this next\" without re-deriving it from AGENTS.md prose each time.",
            "type": [
              "boolean",
              "null"
            ]
          }
        },
        "required": [
          "tool",
          "reason"
        ]
      },
      "FileOverviewOutput": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "language": {
            "type": [
              "string",
              "null"
            ]
          },
          "symbols": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/FileOverviewSymbol"
            }
          },
          "symbol_count": {
            "type": "integer",
            "format": "uint",
            "minimum": 0
          },
          "symbols_truncated": {
            "description": "`true` when `symbols` was capped below `symbol_count` (only `locate`\ncaps; the `file_overview` tool always returns the full list).",
            "type": "boolean"
          },
          "suggested_next": {
            "anyOf": [
              {
                "$ref": "#/$defs/SuggestedNext"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "path",
          "symbols",
          "symbol_count",
          "symbols_truncated"
        ]
      },
      "FileOverviewSymbol": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "qualified_name": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "line_start": {
            "type": "integer",
            "format": "int64"
          },
          "line_end": {
            "type": "integer",
            "format": "int64"
          },
          "caller_count": {
            "type": "integer",
            "format": "int64"
          },
          "is_hub": {
            "type": "boolean"
          },
          "signature": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "qualified_name",
          "kind",
          "line_start",
          "line_end",
          "caller_count",
          "is_hub",
          "signature"
        ]
      },
      "RelatedNoteOutput": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string"
          },
          "excerpt": {
            "description": "First 160 characters of the note's content — not the full note;\ncall `recall(topic=...)` for the whole thing.",
            "type": "string"
          },
          "specificity": {
            "description": "`\"symbol\"` when the note's text mentions the resolved symbol's bare\nname (higher trust), `\"file\"` when it only matched at file level\n(the note references this file but may be about a different symbol\nin it — calibrate trust accordingly).",
            "type": "string"
          },
          "staleness": {
            "description": "`\"fresh\"` / `\"stale\"` / `\"gone\"` (same convention as `recall`'s\nper-note staleness) / `\"unknown\"` when the staleness check itself\nfailed (fail-open: the note still surfaces, just without a\nconfident freshness read).",
            "type": "string"
          }
        },
        "required": [
          "topic",
          "excerpt",
          "specificity",
          "staleness"
        ]
      }
    },
    "properties": {
      "error": {
        "anyOf": [
          {
            "$ref": "#/$defs/ErrorDetail"
          },
          {
            "type": "null"
          }
        ]
      },
      "results": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/SearchResultItem"
        }
      },
      "top_symbol": {
        "anyOf": [
          {
            "$ref": "#/$defs/SymbolInfoOutput"
          },
          {
            "type": "null"
          }
        ]
      },
      "file_overview": {
        "anyOf": [
          {
            "$ref": "#/$defs/FileOverviewOutput"
          },
          {
            "type": "null"
          }
        ]
      },
      "truncated": {
        "type": "boolean"
      },
      "depth_adjusted": {
        "description": "Set when the requested `depth` was auto-downgraded — see\n`CONTRACTS.md`'s `LocateDepth` invariant: `kind ∈ {text, file}` +\n`depth = with_symbol` has no meaningful symbol to enrich, so it's\ndowngraded to `with_file`.",
        "type": [
          "string",
          "null"
        ]
      },
      "personalized": {
        "description": "See `SearchOutput::personalized`.",
        "type": "boolean"
      },
      "related_notes": {
        "description": "Notes saved via `remember` that reference `top_symbol`'s file. Empty\nwhen there's no top_symbol (search_only/with_file depth, or no\nresults) or simply no matching notes — not an error signal. See\n`CalmServer::related_notes` for the specificity/fail-open/content-\nsafety rules governing what qualifies.",
        "type": "array",
        "items": {
          "$ref": "#/$defs/RelatedNoteOutput"
        }
      },
      "suggested_next": {
        "anyOf": [
          {
            "$ref": "#/$defs/SuggestedNext"
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "type": "object"
  },
  "annotations": {
    "readOnlyHint": true,
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": false
  }
}
