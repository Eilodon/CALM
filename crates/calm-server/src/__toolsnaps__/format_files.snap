{
  "name": "format_files",
  "description": "Formats Rust source files via rustfmt — the safe replacement for shelling out to `rustfmt`/`cargo fmt` directly. Only `.rs` files are supported (rustfmt is Rust-specific); a non-Rust path is reported as skipped, not an error. Reindexes any file it actually changes, same as edit_lines/edit_symbol.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "required": [
      "paths"
    ],
    "type": "object",
    "properties": {
      "paths": {
        "description": "Repo-relative paths to format. Only `.rs` files are supported today\n(rustfmt is Rust-specific) — a non-Rust path comes back as\n`skipped_unsupported_extension` in the corresponding result, not a\ntool error, so it's safe to pass a mixed-language batch.",
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "outputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$defs": {
      "ErrorDetail": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "recoverable": {
            "type": "boolean"
          }
        },
        "required": [
          "code",
          "message",
          "recoverable"
        ]
      },
      "FormatFileResult": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "status": {
            "description": "\"formatted\" | \"already_formatted\" | \"skipped_unsupported_extension\" | \"error\".",
            "type": "string"
          },
          "detail": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "path",
          "status"
        ]
      },
      "SuggestedNext": {
        "type": "object",
        "properties": {
          "tool": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "args": true,
          "gate": {
            "description": "Plan 3 §3.5(b): `Some(true)` iff skipping `tool` is actually\nhook-enforced (currently only the edit_context/edit_lines/edit_symbol\n→ diff_impact hints set this, via `suggested_gated`) — every other\nhint is left unset (`None`), meaning advisory-only. Lets an agent\ntell \"you'll be blocked if you skip this\" apart from \"you probably\nwant this next\" without re-deriving it from AGENTS.md prose each time.",
            "type": [
              "boolean",
              "null"
            ]
          }
        },
        "required": [
          "tool",
          "reason"
        ]
      }
    },
    "properties": {
      "error": {
        "anyOf": [
          {
            "$ref": "#/$defs/ErrorDetail"
          },
          {
            "type": "null"
          }
        ]
      },
      "results": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/FormatFileResult"
        }
      },
      "index_stale": {
        "description": "Set only if at least one file was reformatted but the post-write\nindex refresh failed — same meaning as `EditLinesOutput::index_stale`,\ncarrying the failure detail directly instead of a separate bool.",
        "type": [
          "string",
          "null"
        ]
      },
      "suggested_next": {
        "anyOf": [
          {
            "$ref": "#/$defs/SuggestedNext"
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "type": "object"
  },
  "annotations": {
    "readOnlyHint": false,
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": false
  }
}
